{
	"name": "@mdocui/react",
	"version": "0.6.11",
	"description": "React adapter for mdocUI — Renderer, useRenderer hook, default generative UI components",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"test:watch": "vitest",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@mdocui/core": "workspace:*"
	},
	"peerDependencies": {
		"react": ">=18",
		"react-dom": ">=18"
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.0",
		"@types/react": "^19.1.0",
		"@types/react-dom": "^19.1.0",
		"jsdom": "^29.0.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tsup": "^8.5.0",
		"vitest": "^4.1.0",
		"zod": "catalog:"
	},
	"homepage": "https://mdocui.github.io",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/mdocui/mdocui",
		"directory": "packages/react"
	},
	"publishConfig": {
		"access": "public"
	}
}
