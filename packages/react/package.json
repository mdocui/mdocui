{
  "name": "@mdocui/react",
  "version": "0.1.1",
  "description": "React adapter for mdocUI — Renderer, useRenderer hook, default generative UI components",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mdocui/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.0",
    "vitest": "^3.2.0",
    "zod": "catalog:"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mdocui/mdocui",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  }
}
