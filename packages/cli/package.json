{
	"name": "@mdocui/cli",
	"version": "0.6.7",
	"description": "CLI for mdocUI — scaffold, generate system prompts, preview",
	"type": "module",
	"bin": {
		"mdocui": "./dist/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@mdocui/core": "workspace:*",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"tsup": "^8.5.1",
		"vitest": "^4.1.0"
	},
	"homepage": "https://mdocui.github.io",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/mdocui/mdocui",
		"directory": "packages/cli"
	},
	"publishConfig": {
		"access": "public"
	}
}
