{
	"name": "@mdocui/core",
	"version": "0.6.6",
	"description": "Streaming Markdoc parser, component registry, and system prompt generator for LLM generative UI",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"test:watch": "vitest",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"zod": "catalog:"
	},
	"devDependencies": {
		"tsup": "^8.5.0",
		"vitest": "^4.1.0"
	},
	"homepage": "https://mdocui.github.io",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/mdocui/mdocui",
		"directory": "packages/core"
	},
	"keywords": [
		"markdoc",
		"llm",
		"generative-ui",
		"streaming",
		"parser"
	],
	"publishConfig": {
		"access": "public"
	}
}
